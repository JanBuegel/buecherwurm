# Path to the local SQLite database file
DATABASE_URL=./data/buecherwurm.db

# Secret used to sign Auth.js sessions/JWTs.
# Generate one with: openssl rand -base64 32
AUTH_SECRET=

# Base URL of the app (used by Auth.js). Adjust for production.
AUTH_URL=http://localhost:3000

# Optional: Google Books API key. Metadata lookup works without it
# (DNB + Open Library); set this to additionally query Google Books.
# Get one at https://console.cloud.google.com (enable "Books API").
GOOGLE_BOOKS_API_KEY=
